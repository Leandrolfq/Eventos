@model IEnumerable<Eventos.Models.Evento>

@{
    ViewData["Title"] = "Eventos";
}

<div class="fade-in" style="padding: 30px 0;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="persona3-title">Eventos</h1>
        <a asp-action="Create" class="persona3-btn">+ Novo Evento</a>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        @foreach (var item in Model)
        {
            <div class="evento-card">
                <div class="evento-card-banner">
                    @if (!string.IsNullOrEmpty(item.Banner))
                    {
                        <img src="@item.Banner" alt="Banner" />
                    }
                    else
                    {
                        <div class="evento-card-banner-placeholder">📅</div>
                    }
                </div>
                <div class="evento-card-body">
                    <div class="evento-card-title">@item.Nome</div>
                    <div class="evento-card-meta">
                        <span>📅 @item.Data.ToString("dd/MM/yyyy")</span>
                        <span>🕖 @item.Horario</span>
                        <span>📍 @item.Local</span>
                    </div>
                    <div class="evento-card-desc">
                        @{
                            var desc = item.Descricao ?? "";
                            @(desc.Length > 60 ? desc.Substring(0, 60) + "..." : desc)
                        }
                    </div>
                    <div class="evento-card-actions">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-acao btn-editar">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-acao btn-detalhes">Detalhes</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-acao btn-excluir">Excluir</a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>