@model IEnumerable<Eventos.Models.Evento>
@{
    ViewData["Title"] = "Eventos";
}

<div class="fade-in" style="padding: 30px 0;">
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert" style="background-color: rgba(25, 135, 84, 0.2); color: #75b798; border: 1px solid rgba(25, 135, 84, 0.3);">
            @TempData["MensagemSucesso"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert" style="background-color: rgba(220, 53, 69, 0.2); color: #ea868f; border: 1px solid rgba(220, 53, 69, 0.3);">
            @TempData["MensagemErro"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="persona3-title">Eventos</h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="persona3-btn">+ Novo Evento</a>
        }
    </div>

    <form method="get" asp-action="Index" class="row g-3 mb-4">
        <div class="col-md-4">
            <input type="text" name="nome" value="@ViewBag.NomeBusca"
                   class="form-control" placeholder="Nome do evento" />
        </div>
        <div class="col-md-3">
            <select name="categoriaId" class="form-select">
                <option value="">-- Todas as categorias --</option>
                @foreach (var cat in (List<Eventos.Models.Categoria>)ViewBag.Categorias)
                {
                    <option value="@cat.Id" selected="@(ViewBag.CategoriaId == cat.Id)">@cat.Nome</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="palestranteId" class="form-select">
                <option value="">-- Todos os palestrantes --</option>
                @foreach (var pal in (List<Eventos.Models.Palestrante>)ViewBag.Palestrantes)
                {
                    <option value="@pal.Id" selected="@(ViewBag.PalestranteId == pal.Id)">@pal.NomeCompleto</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Buscar</button>
        </div>
    </form>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
        @foreach (var item in Model)
        {
            <div class="evento-card">
                <div class="evento-card-banner">
                    @if (!string.IsNullOrEmpty(item.Banner))
                    {
                        <img src="@item.Banner" alt="Banner" />
                    }
                    else
                    {
                        <div class="evento-card-banner-placeholder">📅</div>
                    }
                </div>
                <div class="evento-card-body d-flex flex-column justify-content-between">
                    <div>
                        <div class="evento-card-title">@item.Nome</div>
                        <div class="evento-card-meta">
                            <span>📅 @item.Data.ToString("dd/MM/yyyy")</span>
                            <span>🕖 @item.Horario</span>
                            <span>📍 @item.Local</span>
                        </div>
                        @if (item.EventoCategorias != null && item.EventoCategorias.Any())
                        {
                            <div style="margin: 8px 0; display: flex; flex-wrap: wrap; gap: 5px;">
                                @foreach (var ec in item.EventoCategorias)
                                {
                                    <span style="background: rgba(127, 212, 255, 0.15); color: #7fd4ff; padding: 2px 8px; border-radius: 12px; font-size: 11px; border: 1px solid rgba(127, 212, 255, 0.3);">
                                        @ec.Categoria.Nome
                                    </span>
                                }
                            </div>
                        }
                        <div class="evento-card-desc">
                            @{
                                var desc = item.Descricao ?? "";
                                @(desc.Length > 60 ? desc.Substring(0, 60) + "..." : desc)
                            }
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="mb-2 w-100">
                            @if (User.Identity.IsAuthenticated)
                            {
                                var inscritoIds = ViewBag.EventosInscritosIds as List<int>;
                                if (inscritoIds != null && inscritoIds.Contains(item.Id))
                                {
                                    <button class="btn btn-secondary w-100 btn-sm" disabled style="background-color: #343a40; border-color: #6c757d; color: #6c757d;">✓ Você está inscrito</button>
                                }
                                else
                                {
                                    <form asp-action="Inscrever" asp-controller="Eventos" method="post" class="w-100">
                                        <input type="hidden" name="eventoId" value="@item.Id" />
                                        <button type="submit" class="btn btn-success w-100 btn-sm" style="background-color: #198754; border: none;">Inscrever-se Rápido</button>
                                    </form>
                                }
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login"
                                   asp-route-returnUrl="@Url.Action("Index", "Eventos")"
                                   class="btn btn-outline-warning w-100 btn-sm" style="font-size: 12px;">
                                    Entre para se inscrever
                                </a>
                            }
                        </div>

                        <div class="evento-card-actions d-flex gap-1 justify-content-between">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-acao btn-editar" style="flex: 1; text-align: center;">Editar</a>
                            }

                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-acao btn-detalhes" style="flex: 2; text-align: center;">Detalhes</a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-acao btn-excluir" style="flex: 1; text-align: center;">Excluir</a>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>