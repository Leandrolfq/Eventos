
@model IEnumerable<Eventos.Models.Evento>

@{
    ViewData["Title"] = "Evento LPQJ";

    var ultimosEventos = Model
        .OrderByDescending(e => e.Data)
        .Take(10)
        .ToList();
}

<style>
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes shine {
        0% {
            background-position: 0% center;
        }

        100% {
            background-position: 200% center;
        }
    }


    body {
        background: #000 !important;
    }

    .home-page {
        min-height: 100vh;
        padding: 25px 15px;
        animation: fadeInUp 1s ease;
    }

    /* HERO */
    .hero-card {
        max-width: 900px;
        margin: auto;
        padding: 45px 35px;
        border-radius: 24px;
        background: rgba(8, 20, 45, 0.88);
        border: 1px solid rgba(127,212,255,0.18);
        box-shadow: 0 0 25px rgba(127,212,255,0.08);
        text-align: center;
    }

    .home-icon {
        font-size: 2.8rem;
        margin-bottom: 15px;
    }

    .home-title {
        font-size: 2.8rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 18px;
        background: linear-gradient(90deg, #7fd4ff, #ffffff, #7fd4ff);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shine 4s linear infinite;
    }

    .event-name {
        display: inline-block;
        margin-bottom: 18px;
        padding: 8px 20px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 700;
        color: #7fd4ff;
        background: rgba(127,212,255,0.10);
        border: 1px solid rgba(127,212,255,0.20);
    }

    .home-text {
        color: #e8f8ff;
        font-size: 1rem;
        line-height: 1.7;
        max-width: 700px;
        margin: auto;
    }

    /* BOTÕES */
    .home-buttons {
        margin-top: 28px;
        display: flex;
        justify-content: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .home-btn {
        padding: 12px 24px;
        border-radius: 12px;
        background: linear-gradient(90deg, #3caeff, #7fd4ff);
        color: #001426 !important;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.9rem;
        text-decoration: none;
        transition: 0.3s ease;
    }

        .home-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px rgba(127,212,255,0.30);
        }

    /* TÍTULO EVENTOS */
    .section-title {
        margin-top: 55px;
        margin-bottom: 25px;
        text-align: center;
        font-size: 2rem;
        font-weight: 900;
        color: #7fd4ff;
    }

    /* GRID */
    .events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }

    /* CARD EVENTO */
    .event-card {
        background: rgba(8, 20, 45, 0.88);
        border: 1px solid rgba(127,212,255,0.15);
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s ease;
    }

        .event-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0 25px rgba(127,212,255,0.15);
        }

    .event-banner {
        width: 100%;
        height: 170px;
        object-fit: cover;
    }

    .event-content {
        padding: 18px;
    }

    .event-title {
        color: #7fd4ff;
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .event-date {
        color: #cfefff;
        font-size: 0.9rem;
    }

    .event-btn {
        margin-top: 15px;
        display: inline-block;
        padding: 9px 16px;
        border-radius: 10px;
        background: linear-gradient(90deg, #3caeff, #7fd4ff);
        color: #001426 !important;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        transition: 0.3s ease;
    }

        .event-btn:hover {
            transform: scale(1.03);
        }

    /* RESPONSIVO */
    @@media(max-width: 768px) {

        .hero-card {
            padding: 35px 20px;
        }

        .home-title {
            font-size: 2rem;
        }

        .section-title {
            font-size: 1.6rem;
        }

        .event-banner {
            height: 150px;
        }
    }
</style>

<div class="home-page">

    
    <div class="hero-card">

        <div class="home-icon">😎</div>

        <h1 class="home-title">
            Palestras Feitas pra Você
        </h1>

        <div class="event-name">
            Evento LPQJ
        </div>

        <p class="home-text">
            Participe das palestras disponíveis no momento e escolha aquela
            que mais chamar sua atenção.
        </p>



        <div class="home-buttons">

            <a asp-controller="Palestrantes"
               asp-action="Index"
               class="home-btn">
                Ver Palestrantes
            </a>

            <a asp-controller="Eventos"
               asp-action="Index"
               class="home-btn">
                Ver Eventos
            </a>

        </div>
    </div>

    <!-- EVENTOS -->
    <h2 class="section-title">
        Últimos Eventos
    </h2>

    <div class="events-grid">

        @foreach (var item in ultimosEventos)
        {
            <div class="event-card">

                @if (!string.IsNullOrEmpty(item.Banner))
                {
                    <img src="@item.Banner"
                         class="event-banner"
                         alt="Banner do evento" />
                }

                <div class="event-content">

                    <div class="event-title">
                        @item.Nome
                    </div>

                    <div class="event-date">
                        📅 @item.Data.ToString("dd/MM/yyyy")
                    </div>

                    <a asp-controller="Eventos"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="event-btn">
                        Ver Detalhes
                    </a>

                </div>
            </div>
        }

    </div>

</div>
