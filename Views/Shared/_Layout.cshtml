<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eventos</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Eventos.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="nav-link nav-menu-btn fw-bold d-inline-block p-2" asp-area="" asp-controller="Home" asp-action="Index">LPJQ</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @* Links visíveis para todos - Classes originais restauradas *@
                        <li class="nav-item">
                            <a class="nav-link nav-menu-btn" asp-area="" asp-controller="Eventos" asp-action="Index">Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-menu-btn" asp-area="" asp-controller="Palestrantes" asp-action="Index">Palestrantes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-menu-btn" asp-area="" asp-controller="Contatos" asp-action="Create">Contato</a>
                        </li>

                        @* Links visíveis apenas para Admin *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-menu-btn text-warning" asp-area="" asp-controller="Categorias" asp-action="Index">Categorias</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-menu-btn text-warning" asp-area="" asp-controller="Contatos" asp-action="Index">Gerenciar Contatos</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post" class="form-inline">
                                    <button type="submit" class="nav-link btn btn-link text-danger border-0 p-0 m-0">Sair (@User.Identity.Name)</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            @* Links da direita personalizados com a sua classe também *@
                            <li class="nav-item">
                                <a class="nav-link nav-menu-btn" asp-area="Identity" asp-page="/Account/Login">Entrar</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-menu-btn" asp-area="Identity" asp-page="/Account/Register">Registrar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Eventos - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>