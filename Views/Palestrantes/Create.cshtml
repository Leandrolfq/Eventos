@model Eventos.Models.Palestrante

@{
    ViewData["Title"] = "Novo Palestrante";
}

<div class="fade-in" style="padding: 30px 0;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="persona3-title">Novo Palestrante</h1>
        <a asp-action="Index" class="btn-acao btn-detalhes">← Voltar</a>
    </div>

    <div class="persona3-card" style="max-width: 600px;">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="NomeCompleto" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="NomeCompleto" class="form-control" />
                <span asp-validation-for="NomeCompleto" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Empresa" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="Empresa" class="form-control" />
                <span asp-validation-for="Empresa" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Especialidade" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="Especialidade" class="form-control" />
                <span asp-validation-for="Especialidade" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MiniBiografia" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <textarea asp-for="MiniBiografia" class="form-control" rows="4"></textarea>
                <span asp-validation-for="MiniBiografia" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;">Foto</label>
                <input type="file" name="Foto" accept="image/*,image/gif,video/mp4,video/*" class="form-control" />
            </div>

            <div class="d-flex gap-3">
                <input type="submit" value="Criar Palestrante" class="persona3-btn" style="cursor: pointer;" />
                <a asp-action="Index" class="btn-acao btn-detalhes" style="padding: 12px 20px;">Cancelar</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}