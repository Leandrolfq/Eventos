@model Eventos.Models.Contato

@{
    ViewData["Title"] = "Novo Contato";
}

<div class="fade-in" style="padding: 30px 0;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="persona3-title">Novo Contato</h1>
        <a asp-action="Index" class="btn-acao btn-detalhes">← Voltar</a>
    </div>

    <div class="persona3-card" style="max-width: 600px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Nome" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Email" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Assunto" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="Assunto" class="form-control" />
                <span asp-validation-for="Assunto" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Mensagem" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <textarea asp-for="Mensagem" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Mensagem" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="DataEnvio" class="control-label" style="color: #7fd4ff; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; font-size: 12px;"></label>
                <input asp-for="DataEnvio" class="form-control" />
                <span asp-validation-for="DataEnvio" class="text-danger"></span>
            </div>

            <div class="d-flex gap-3">
                <input type="submit" value="Enviar Contato" class="persona3-btn" style="cursor: pointer;" />
                <a asp-action="Index" class="btn-acao btn-detalhes" style="padding: 12px 20px;">Cancelar</a>
            </div>
        </form>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}