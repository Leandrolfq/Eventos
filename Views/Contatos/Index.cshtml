@model IEnumerable<Eventos.Models.Contato>

@{
    ViewData["Title"] = "Contatos";
}

<div class="fade-in" style="padding: 30px 0;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="persona3-title">Contatos</h1>
        <a asp-action="Create" class="persona3-btn">+ Novo Contato</a>
    </div>

    <div class="persona3-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle persona3-table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Assunto</th>
                        <th>Mensagem</th>
                        <th>Data de Envio</th>
                        <th style="text-align: center;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="color: #7fd4ff; font-weight: 700;">
                                @Html.DisplayFor(modelItem => item.Nome)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Email)
                            </td>
                            <td>
                                <span style="background: rgba(127,212,255,0.12); color: #7fd4ff;
                                    border: 1px solid rgba(127,212,255,0.25); border-radius: 20px;
                                    font-size: 11px; font-weight: 700; padding: 4px 12px;
                                    text-transform: uppercase; letter-spacing: 0.5px;">
                                    @Html.DisplayFor(modelItem => item.Assunto)
                                </span>
                            </td>
                            <td style="max-width: 250px;">
                                @{
                                    var msg = item.Mensagem ?? "";
                                    @(msg.Length > 60 ? msg.Substring(0, 60) + "..." : msg)
                                }
                            </td>
                            <td>
                                @item.DataEnvio.ToString("dd/MM/yyyy")
                            </td>
                            <td style="text-align: center;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-acao btn-editar">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-acao btn-detalhes">Detalhes</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-acao btn-excluir">Excluir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>